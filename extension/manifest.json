{
  "manifest_version": 3,
  "name": "Browser Omnibox – Tab Sync",
  "version": "1.0.0",
  "description": "Syncs open tabs with the Browser Omnibox Flow Launcher plugin.",
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:7323/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html"
}
