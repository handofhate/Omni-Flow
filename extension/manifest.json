{
  "manifest_version": 3,
  "name": "Omni Flow Tab Sync",
  "version": "1.0.3",
  "description": "Companion extension that syncs open tabs with the Omni Flow plugin.",
  "permissions": [
    "tabs",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "http://127.0.0.1:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html"
}
